# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project URL and keys are available in your Supabase dashboard:
#   Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — server-side ONLY. Never expose this to the browser.
# Used by the API route handlers to bypass RLS for trusted operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---------------------------------------------------------------------------
# Embeddings (Sprint 1 uses the built-in deterministic mock provider)
# ---------------------------------------------------------------------------
# Selects the embedding implementation in src/lib/embeddings.ts.
# Supported now: "mock". Future: "openai", "nvidia".
EMBEDDING_PROVIDER=mock

# Required only once a real provider is wired in:
# OPENAI_API_KEY=
# NVIDIA_API_KEY=
