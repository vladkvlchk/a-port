# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Project URL and keys are available in your Supabase dashboard:
#   Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — server-side ONLY. Never expose this to the browser.
# Used by the API route handlers to bypass RLS for trusted operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---------------------------------------------------------------------------
# Embeddings (Sprint 1/2 use the built-in deterministic mock provider)
# ---------------------------------------------------------------------------
# Selects the embedding implementation in src/lib/embeddings.ts.
# Supported now: "mock". Future: "openai", "nvidia".
EMBEDDING_PROVIDER=mock

# ---------------------------------------------------------------------------
# LLM judge — NemoClaw arbitration (POST /api/disputes/arbitrate)
# ---------------------------------------------------------------------------
# The judge tries providers in order: Anthropic -> Groq -> OpenAI, and falls
# back to a deterministic heuristic when no key is set.
ANTHROPIC_API_KEY=
# Optional model override for the Anthropic judge (default: claude-opus-4-8).
LLM_MODEL=claude-opus-4-8

# Optional non-Claude fallbacks:
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Twilio — emergency broadcast (POST /api/simulation/trigger-flashcrash)
# ---------------------------------------------------------------------------
# When unset, the broadcast runs in SIMULATED mode (no real SMS/calls).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Comma-separated list of recipient numbers, e.g. +15551234567,+15557654321
TWILIO_ALERT_NUMBERS=

# ---------------------------------------------------------------------------
# CLI (src/cli.ts)
# ---------------------------------------------------------------------------
# Base URL the `aport` CLI targets. Defaults to http://localhost:3000.
APORT_API_URL=http://localhost:3000
